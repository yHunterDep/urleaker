    "GOOGLE DRIVE": [r"(?i)https://drive\.google\.com/file/d/\S{,50}"],
    "INNER HTML": [r"(?i)[\w$.]+\.innerHTML\s*=\s*[^;]{1,30}"],
    "HREF OBJECT": [r"(?i)(?:location|window\.location|document\.location)(?:\.href)?\s*=\s*[^;]{1,35}"]
    #"HIGH_ENTROPY_STRING": r"[A-Za-z0-9+/=]{40,}"
    }

}

padraos_args = {}

if args.api:
        padraos_args.update(PADRAOS["api"])
if args.tokens:
        padraos_args.update(PADRAOS["tokens"])
if args.credentials:
        padraos_args.update(PADRAOS["cred"])
if args.keys:
        padraos_args.update(PADRAOS["keys"])
if args.generic:
        padraos_args.update(PADRAOS["generic"])
if args.html:
        padraos_args.update(PADRAOS["html"])

if not padraos_args:
        padraos_args.update(PADRAOS["api"])
        padraos_args.update(PADRAOS["tokens"])
        padraos_args.update(PADRAOS["cred"])
        padraos_args.update(PADRAOS["keys"])
        padraos_args.update(PADRAOS["generic"])
        padraos_args.update(PADRAOS["html"])

def js_req(url):
        try:
                r = requests.get(url)
        except:
                return

        for nome, regex_list in padraos_args.items():
                for regex in regex_list:
                        rgx = re.findall(regex, r.text)

                        if rgx:
                                rgx = list(set(rgx))
                                rgx = f"{RST}, {RX}".join(rgx)
                                rgx = re.findall(r"\S+", rgx) #PARA LIMPAR STRINGS COM "\t" E "\n"
                                rgx = " ".join(rgx)
                                print(f"{RST}[{VD}{nome}{RST}] {FRT}[{url}]{RST} [{RX}{rgx}{RST}]\n")

with ThreadPoolExecutor(max_workers=20) as executor:
    futures = [executor.submit(js_req, u) for u in file]

    for future in as_completed(futures):
        if future.result():
                print(future.result())
