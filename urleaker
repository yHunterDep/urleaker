#!/usr/bin/python3

import re, requests, argparse, random, os
from concurrent.futures import ThreadPoolExecutor, as_completed

parser = argparse.ArgumentParser(description="URLeaker - By HunterDep ^^")
parser.add_argument("-f", "--file", required=True, help="Put file to scan. Ex: -f urls-js.txt")
parser.add_argument("-sv", "--severities", help="Choice severities to scan (-sv unknown,low,medium,high,critical)")
parser.add_argument("-api", "--api", action="store_true", help="Find APIKeys (Google, AWS, Firebase, etc)")
parser.add_argument("-t", "--tokens", action="store_true", help="Find Tokens (Discord, Slack, Github, etc)")
parser.add_argument("-cr", "--credentials", action="store_true", help="Find Credentials (Email, passowrds, etc)")
parser.add_argument("-k", "--keys", action="store_true", help="Find private key")
parser.add_argument("-g", "--generic", action="store_true", help="Find generic API Key")
parser.add_argument("-html", "--html", action="store_true", help="Find intersting object html")
parser.add_argument("-c", "--concurrent", help="Number of concurrent threads (default: 20)", default=20, type=int)
parser.add_argument("-s", "--silent", action="store_true", help="Skip banner mode")
parser.add_argument("-nc", "--no_color", action="store_true", help="Remove colors from output")
args = parser.parse_args()

if args.no_color:
	VD=AZ=VR=AM=FRT=RST=""
else:
	#RX = "\033[35m"
	VD = "\033[32m"
	AZ = "\033[34m"
	VR = "\033[31m"
	AM = "\033[33m"
	FRT = "\033[1;37m"
	RST = "\033[0m"

if not args.silent:
	banner = fr"""{AZ}
   __  ______  __               __
  / / / / __ \/ /   ___  ____ _/ /_____  _____
 / / / / /_/ / /   / _ \/ __ `/ //_/ _ \/ ___/
/ /_/ / _, _/ /___/  __/ /_/ / ,< /  __/ /
\____/_/ |_/_____/\___/\__,_/_/|_|\___/_/{RST}

	{FRT}A Powerfull secret scanner 🔍
	Coded By HunterDep ^^
	Version: 0.2
"""

	print(banner)

unknown = f"unknown"
info = f"{AZ}info{RST}"
low = f"{VD}low{RST}"
medium = f"{AM}medium{RST}"
high = f"{VR}high{RST}"
critical = f"{FRT+VR}critical{RST}"

file = open(args.file, "r").read().split()
severities = None
if args.severities:
	severities = args.severities.split(",")

def user_agent():
    USER_AGENTS = [
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/119.0.0.0 Safari/537.36",
        "Mozilla/5.0 (Macintosh; Intel Mac OS X 13_5) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Safari/605.1.15",
    ]

    headers = {
        "User-Agent": random.choice(USER_AGENTS)
    }
    return headers

