padraos_args = {}

if args.api:
	padraos_args.update(PADRAOS["api"])
if args.tokens:
	padraos_args.update(PADRAOS["tokens"])
if args.credentials:
	padraos_args.update(PADRAOS["cred"])
if args.keys:
	padraos_args.update(PADRAOS["keys"])
if args.generic:
	padraos_args.update(PADRAOS["generic"])
if args.html:
	padraos_args.update(PADRAOS["html"])

if not padraos_args:
	padraos_args.update(PADRAOS["api"])
	padraos_args.update(PADRAOS["tokens"])
	padraos_args.update(PADRAOS["cred"])
	padraos_args.update(PADRAOS["keys"])
	padraos_args.update(PADRAOS["generic"])
	padraos_args.update(PADRAOS["html"])

if severities:
	filtro = {}
	for k,v in padraos_args.items():
		severity = v[1]
		for s in severities:
			if s in severity:
				filtro[k] = v

	padraos_args = filtro

def js_req(url):
	try:
		r = requests.get(url, headers=user_agent(), timeout=5)
	except:
		return

	for nome, regex_list in padraos_args.items():
		severity = regex_list[1]
		# regex_list[0] => REGEX'S
		# regex_list[1] => SEVERITY
		for regex in regex_list[0]:
			rgx = re.findall(regex, r.text)

			if rgx:
				rgx = list(set(rgx))
				rgx = f"{RST}, {FRT+AZ}".join(rgx)
				rgx = " ".join(rgx.split())
				print(f"{RST}[{VD}{nome}{RST}] ({severity}) {FRT}[{url}]{RST} [{FRT+AZ}{rgx}{RST}]\n", flush=True)

with ThreadPoolExecutor(max_workers=args.concurrent) as executor:
    futures = [executor.submit(js_req, u) for u in file]

    for future in as_completed(futures):
        if future.result():
	        print(future.result())
